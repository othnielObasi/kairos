# KAIROS — Arc Quick-Start (.env)
# ══════════════════════════════════════════════════════════════
# cp .env.hackathon.example .env   then fill in your keys
# See .env.example for full documentation of every variable
# ══════════════════════════════════════════════════════════════

# ──── Mode ────
DATA_SOURCE=live
MODE=live

# ──── Wallet / Arc Testnet ────
PRIVATE_KEY=
RPC_URL=https://rpc.testnet.arc.network
CHAIN_ID=5042002

# ──── Circle Wallets (create at console.circle.com) ────

CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=
AGENT_WALLET_ADDRESS=

# ──── Nanopayments ($0.001 USDC per event on Arc) ────
GOVERNANCE_BILLING_ADDRESS=
NANOPAYMENT_AMOUNT_USDC=0.001
MICRO_COMMERCE_SETTLEMENT_ADDRESS=
TRACK4_SETTLEMENT_AMOUNT_USDC=0.009

# ──── x402 Data Payments (AIsa endpoints on Arc) ────
OWS_MNEMONIC=
OWS_RPC_URL=https://rpc.testnet.arc.network
OWS_CHAIN_ID=5042002
AISA_BASE_URL=https://api.aisa.one/apis/v2
GATEWAY_CONTRACT=0x0077777d7eba4688bdef3e311b846f25870a19b9

# ──── LLM Keys (optional) ────
ANTHROPIC_API_KEY=
# Gemini primary/secondary failover for runtime + SAGE reflection
GEMINI_API_KEY_PRIMARY=
GEMINI_API_KEY_SECONDARY=
# Backward-compatible single-key alias
GEMINI_API_KEY=
GEMINI_RUNTIME_MODEL=gemini-3-flash-preview
GEMINI_RUNTIME_MODELS=gemini-3-flash-preview,gemini-2.5-flash
GEMINI_REFLECTION_MODEL=gemini-3-pro-preview
GEMINI_REFLECTION_MODELS=gemini-3-pro-preview,gemini-3-flash-preview,gemini-2.5-flash
# OpenAI runs after both Gemini keys fail
OPENAI_API_KEY=

# ──── Routing & Identity Contracts ────
AGENT_REGISTRY_ADDRESS=
RISK_ROUTER_ADDRESS=
RISK_POLICY_ADDRESS=
DEX_ROUTER_ADDRESS=
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ──── Agent ────
AGENT_NAME=Kairos
AGENT_DESCRIPTION=Arc-native agentic payments runtime
AGENT_ID=
AGENT_IMAGE_URL=
DASHBOARD_URL=http://localhost:3000
MCP_ENDPOINT=http://localhost:3001/mcp
A2A_ENDPOINT=http://localhost:3000/.well-known/agent-card.json

# ──── Current Demo Loop Controls ────
TRADING_PAIR=WETH/USDC
MAX_POSITION_PCT=10
MAX_DAILY_LOSS_PCT=2
MAX_DRAWDOWN_PCT=8
TRADING_INTERVAL_MS=120000
MANDATE_CAPITAL_USD=100000
MAX_HOLD_HOURS=4
ALLOWED_ASSETS=WETH/USDC,ETH,USDC
ALLOWED_PROTOCOLS=uniswap,aerodrome

# ──── SAGE ────
SAGE_ENABLED=true
