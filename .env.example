# KAIROS — Complete Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Settlement: Arc Testnet (Circle's EVM-compatible L1 for USDC)
# Payments:   Circle Nanopayments + x402 via Circle Gateway
# ═══════════════════════════════════════════════════════════════

# ──── Mode ────
DATA_SOURCE=live
MODE=live

# ──── Wallet (EOA fallback — NEVER commit real keys) ────
PRIVATE_KEY=

# ──── Arc Testnet (primary settlement chain) ────
RPC_URL=https://rpc.testnet.arc.network
CHAIN_ID=5042002

# ──── Circle Developer-Controlled Wallets (recommended) ────
# Create at: https://console.circle.com/wallets
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=
AGENT_WALLET_ADDRESS=

# ──── Circle Nanopayments (real USDC micro-transfers on Arc) ────
# Recipient for governance/compute billing events ($0.001 each)
# For demo: set to your own wallet address to self-pay
GOVERNANCE_BILLING_ADDRESS=
NANOPAYMENT_AMOUNT_USDC=0.001
# Optional: separate key for nanopayment signing (defaults to PRIVATE_KEY)
NANOPAYMENT_PRIVATE_KEY=

# ──── x402 Data Payments (Track 2 — AIsa endpoints) ────
# BIP-39 mnemonic for x402 signing wallet on Arc
OWS_MNEMONIC=
OWS_RPC_URL=https://rpc.testnet.arc.network
OWS_CHAIN_ID=5042002
# Alternate mnemonic env name (either works)
X402_MNEMONIC=
# AIsa base URL for paid data feeds (prices, sentiment, PRISM)
AISA_BASE_URL=https://api.aisa.one/apis/v2
# Circle Gateway contract for x402 settlement
GATEWAY_CONTRACT=0x0077777d7eba4688bdef3e311b846f25870a19b9

# ──── LLM API Keys (for AI-powered trade explainability) ────
# Works without these (deterministic fallback). With keys → rich reasoning.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ──── IPFS (Pinata — free at https://app.pinata.cloud) ────
PINATA_JWT=
PINATA_GATEWAY=

# ──── Agent Identity ────
AGENT_NAME=Kairos
AGENT_DESCRIPTION=Accountable autonomous trading agent on Arc
AGENT_ID=
AGENT_IMAGE_URL=
DASHBOARD_URL=http://localhost:3000
MCP_ENDPOINT=http://localhost:3001/mcp
A2A_ENDPOINT=http://localhost:3000/.well-known/agent-card.json
REGISTRATION_OUT=agent-registration.json
REGISTRATION_URI=

# ──── Hackathon Contracts (Arc Testnet) ────
AGENT_REGISTRY_ADDRESS=
HACKATHON_VAULT_ADDRESS=
RISK_ROUTER_ADDRESS=
RISK_POLICY_ADDRESS=
IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
VALIDATION_REGISTRY=0x8004Cb1BF31DAf7788923b405b754f57acEB4272
REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713
CAPITAL_VAULT_ADDRESS=
DEX_ROUTER_ADDRESS=
USDC_ADDRESS=0x3600000000000000000000000000000000000000
WETH_ADDRESS=


# ──── Trading ────
TRADING_PAIR=WETH/USDC
MAX_POSITION_PCT=10
MAX_DAILY_LOSS_PCT=2
MAX_DRAWDOWN_PCT=8
TRADING_INTERVAL_MS=120000
MANDATE_CAPITAL_USD=100000
MAX_HOLD_HOURS=4
MAX_LOSS_PER_TRADE=
TAKE_PROFIT_PCT=
ALLOWED_ASSETS=WETH/USDC,ETH,USDC
ALLOWED_PROTOCOLS=uniswap,aerodrome
RESTRICTED_ASSETS=
RESTRICTED_PROTOCOLS=
REQUIRE_HUMAN_APPROVAL_ABOVE_USD=20000

# ──── Data Feeds ────
# Kraken (live price source — no key needed for public API)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_CLI_PATH=kraken
KRAKEN_CLI_TIMEOUT_MS=30000
KRAKEN_PAPER_TRADING=true
# PRISM (Strykr — optional technical indicator feed)
PRISM_API_KEY=
# Alpha Vantage (news sentiment — optional)
ALPHAVANTAGE_API_KEY=

# ──── SAGE (Self-Adapting Generative Engine) ────
SAGE_ENABLED=true
SAGE_MIN_OUTCOMES=5
SAGE_REFLECTION_COOLDOWN=10
SAGE_MAX_RULES=20
SAGE_RULE_TTL_MS=604800000
SAGE_PERSIST_SEED=false

# ──── Dashboard / Server ────
PORT=3000

# ──── Bootstrap Flags ────
SKIP_REGISTER=false
CLAIM_SANDBOX=false
RUN_ONCHAIN_DEMO=false
