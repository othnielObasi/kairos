# ACTURA — Environment Configuration
# ═══════════════════════════════════════════

# Data source: 'live' = real ETH prices from CoinGecko/DeFiLlama
#              'simulated' = synthetic random-walk prices
DATA_SOURCE=live

# Mode: 'simulation' = run N cycles fast then exit
#        'live' = scheduled continuous trading with dashboard + MCP
MODE=simulation

# Wallet (export from MetaMask — NEVER commit real keys)
PRIVATE_KEY=

# ──── LLM API Keys (for AI-powered trade explainability) ────
# The agent works fine without these (uses deterministic fallback).
# With keys you get rich human-readable reasoning per trade.

# Primary: Anthropic Claude Sonnet (best structured JSON output)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Failover: Google Gemini Flash (free tier — 15 RPM / 1M tokens/day)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Third failover: OpenAI GPT-4o-mini (cheap, reliable)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Network (Base Sepolia)
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# ERC-8004 Registries (Reference Implementation — live on Base Sepolia)
IDENTITY_REGISTRY=0x7177a6867296406881E20d6647232314736Dd09A
REPUTATION_REGISTRY=0xB5048e3ef1DA4E04deB6f7d0423D06F63869e322
VALIDATION_REGISTRY=0x662b40A526cb4017d947e71eAF6753BF3eeE66d8

# IPFS (Pinata — free at https://app.pinata.cloud)
PINATA_JWT=
# Dedicated gateway (get one at https://app.pinata.cloud/gateway)
# Falls back to https://ipfs.io/ipfs if not set
PINATA_GATEWAY=

# Agent
AGENT_NAME=Actura
AGENT_DESCRIPTION=Accountable autonomous trading agent
AGENT_ID=

# Validator (second wallet — cannot be same as agent wallet)
VALIDATOR_PRIVATE_KEY=

# Hackathon (TBD — set when organizers publish)
RISK_ROUTER_ADDRESS=
CAPITAL_VAULT_ADDRESS=

# Trading
TRADING_PAIR=WETH/USDC
MAX_POSITION_PCT=10
MAX_DAILY_LOSS_PCT=2
MAX_DRAWDOWN_PCT=8
TRADING_INTERVAL_MS=60000

# Mode: simulation | live
MODE=simulation
